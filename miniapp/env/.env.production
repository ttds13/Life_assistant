# 变量必须以 VITE_ 为前缀才能暴露给外部读取
NODE_ENV = 'production'
VITE_WX_APPID = 'wx4239a68b523d3bdd'
# 是否去除console 和 debugger
VITE_DELETE_CONSOLE = false
# 是否开启sourcemap
VITE_SHOW_SOURCEMAP = false

# 后台请求地址：局域网真机/微信开发者工具联调后端
VITE_SERVER_BASEURL = 'http://192.168.37.18:3100/api'
VITE_SERVER_BASEURL_SECONDARY = 'http://192.168.37.18:3100/api'

# 本地调试：启动小程序后自动以 ttds 账号登录
VITE_LOCAL_DEBUG_LOGIN = true
VITE_LOCAL_DEBUG_AUTO_LOGIN = true
VITE_LOCAL_DEBUG_LOGIN_PHONE = '13800001111'
