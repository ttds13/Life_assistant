VITE_APP_TITLE = '生活助手'
VITE_APP_PORT = 5173

VITE_UNI_APPID = '__UNI__LIFE_ASSISTANT'
VITE_WX_APPID = 'touristappid'

# h5部署网站的base，配置到 manifest.config.ts 里的 h5.router.base
# https://uniapp.dcloud.net.cn/collocation/manifest.html#h5-router
# 比如你要部署到 https://unibest.tech/doc/ ，则配置为 /doc/
VITE_APP_PUBLIC_BASE=/

# 后台请求地址
VITE_SERVER_BASEURL = 'http://192.168.37.18:3100/api'
# 备注：如果后台带统一前缀，则也要加到后面，eg: http://localhost:3000/api

# 注意，如果是微信小程序，还有一套请求地址的配置，根据 develop、trial、release 分别设置上传地址，见 `src/utils/index.ts`。

# h5是否需要配置代理
VITE_APP_PROXY_ENABLE = true
# 下面的不用修改，只要不跟你后台的统一前缀冲突就行。如果修改了，记得修改 `nginx` 里面的配置
VITE_APP_PROXY_PREFIX = '/api'

# 第二个请求地址，Day 1 暂不使用
VITE_SERVER_BASEURL_SECONDARY = 'http://192.168.37.18:3100/api'

# 认证模式，'single' | 'double' ==> 单token | 双token
VITE_AUTH_MODE = 'single'

# 默认语言
VITE_FALLBACK_LOCALE = 'zh-Hans'

# 是否去除console 和 debugger，Day 1 保留日志便于联调
VITE_DELETE_CONSOLE = false

# 原生插件资源复制开关，控制是否启用 copy-native-resources 插件
VITE_COPY_NATIVE_RES_ENABLE = false
